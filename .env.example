# ============================================
# AI Content Studio — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# ---------- General ----------
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ORIGINS=http://localhost:3000

# ---------- Database (PostgreSQL) ----------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_content_studio

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- JWT ----------
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Email (SMTP) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=AI Content Studio

# ---------- Encryption (for API keys at rest) ----------
ENCRYPTION_KEY=change-me-32-byte-base64-encoded-key

# ---------- Storage (S3-Compatible / Cloudflare R2) ----------
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=ai-content-studio
S3_REGION=auto

# ---------- Rate Limiting ----------
RATE_LIMIT_PER_MINUTE=60

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
